# FetchAPI — Environment Configuration
# Copy this file to .env and fill in real values before running.
# Never commit .env to source control.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_SECRET_KEY=change-me-in-production
# Default workspace UUID used in single-tenant local setup
APP_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fetchapi
POSTGRES_USER=fetchapi
POSTGRES_PASSWORD=fetchapi
POSTGRES_POOL_SIZE=20

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=fetch_chunks_v1
QDRANT_POOL_SIZE=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_CACHE_TTL_SECONDS=3600

# ── Object Storage (MinIO locally / S3-compatible in deployment) ──────────────
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=fetchapi-snapshots
OBJECT_STORAGE_REGION=us-east-1

# ── Worker (ingestion runs as asyncio background tasks — no broker needed) ────
# Maximum times a failed ingestion job is retried before staying FAILED
WORKER_INGESTION_MAX_RETRIES=3
# Maximum YAML alias expansions before the ingestion is aborted
WORKER_INGESTION_MAX_ALIASES=100

# ── LLM — NVIDIA NIM (OpenAI-compatible) ─────────────────────────────────────
LLM_PROVIDER=nvidia_nim
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=your-nvidia-nim-api-key
LLM_MODEL_ID=meta/llama-3.1-70b-instruct
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=4096

# ── Embeddings — NVIDIA NIM ───────────────────────────────────────────────────
EMBEDDINGS_PROVIDER=nvidia_nim
EMBEDDINGS_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDINGS_API_KEY=your-nvidia-nim-api-key
EMBEDDINGS_MODEL_ID=nvidia/nv-embed-v2
EMBEDDINGS_DIMENSION=4096
EMBEDDINGS_BATCH_SIZE=32

# ── Reranker — NVIDIA NIM ─────────────────────────────────────────────────────
RERANKER_PROVIDER=nvidia_nim
RERANKER_BASE_URL=https://integrate.api.nvidia.com/v1
RERANKER_API_KEY=your-nvidia-nim-api-key
RERANKER_MODEL_ID=nvidia/nv-rerankqa-mistral-4b-v3

# ── Retrieval defaults ────────────────────────────────────────────────────────
DENSE_CANDIDATE_LIMIT=25
SPARSE_CANDIDATE_LIMIT=25
FUSED_CANDIDATE_LIMIT=30
RERANK_LIMIT=10
FINAL_EVIDENCE_LIMIT=6
MAX_EVIDENCE_TOKENS=6000

# ── Upload limits ─────────────────────────────────────────────────────────────
# 10 MB max file size
UPLOAD_MAX_FILE_BYTES=10485760
UPLOAD_MAX_OPERATIONS=500

# ── External reference resolution limits ──────────────────────────────────────
EXT_REF_MAX_HOPS=3
EXT_REF_MAX_BYTES=1048576
EXT_REF_TIMEOUT_SECONDS=10

# ── Security ──────────────────────────────────────────────────────────────────
SECURITY_ALLOWED_HOSTS=*
SECURITY_CORS_ORIGINS=http://localhost:3000

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=fetchapi
# Leave blank to disable OTLP export during local development
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# ── Crawler (deferred — Phase 4, do not implement in Phases 0–3) ──────────────
# CRAWLER_MAX_PAGES=100
# CRAWLER_MAX_DEPTH=5
# CRAWLER_MAX_BYTES=52428800
# CRAWLER_MAX_DURATION_SECONDS=300
